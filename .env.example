# App
NODE_ENV=development
PORT=3000
API_PORT=4000
API_HOST_PORT=4000
APP_URL=http://127.0.0.1:3000
WEB_BIND_ADDR=127.0.0.1
WEB_PORT=3000
VITE_API_BASE_URL=/api
VITE_AUTH_MODE=protected
VITE_IDLE_LOGOUT_MINUTES=15

# Owner portal
# Online appointment requests are intentionally disabled for the first owner-cabinet release.
CLIENT_PORTAL_ONLINE_REQUESTS_ENABLED=false
CLIENT_PORTAL_CODE_TTL_MINUTES=10
CLIENT_PORTAL_CODE_MAX_ATTEMPTS=5
CLIENT_PORTAL_PHONE_TOKEN_DAYS=30
CLIENT_PORTAL_PUBLIC_URL=

# Outbound-only synchronization to the separate public owner gateway.
# Leave both values empty until a public gateway target has been approved and deployed.
OWNER_GATEWAY_URL=
OWNER_GATEWAY_SYNC_SECRET=
OWNER_GATEWAY_REQUEST_TIMEOUT_MS=30000
NOTIFICATION_DISPATCH_INTERVAL_MS=30000
CRM_SOURCE_VERSION=local

# MAX bot (keep real secrets only in .env, never commit them)
MAX_BOT_NAME=
MAX_BOT_TOKEN=
MAX_API_BASE_URL=https://platform-api2.max.ru
NODE_EXTRA_CA_CERTS=/app/certs/russian_trusted_root_ca.pem

# Telegram will use the same owner portal after its bot is connected.
TELEGRAM_BOT_USERNAME=
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_API_BASE_URL=https://api.telegram.org

# Docker images
# Local/offline installation uses images loaded from flash drive.
# When remote images are configured, launcher can pull fresh api/web images on startup.
TEMICHEVVET_API_IMAGE=temichevvet-api:local
TEMICHEVVET_WEB_IMAGE=temichevvet-web:local
TEMICHEVVET_REMOTE_API_IMAGE=ghcr.io/pivotemnoe/kliniksrm-api:stable
TEMICHEVVET_REMOTE_WEB_IMAGE=ghcr.io/pivotemnoe/kliniksrm-web:stable
TEMICHEVVET_AUTO_PULL_IMAGES=true

# Automatic local backups
# 18000 seconds = every 5 hours. Backups are written to ./backups.
BACKUP_INTERVAL_SECONDS=18000
BACKUP_RETENTION_DAYS=14

# Database
POSTGRES_DB=clinic_crm
POSTGRES_USER=clinic_crm
POSTGRES_PASSWORD=clinic_crm
POSTGRES_PORT=5433
DATABASE_URL=postgresql://clinic_crm:clinic_crm@localhost:5433/clinic_crm

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# S3-compatible storage
MINIO_ROOT_USER=clinic-crm
MINIO_ROOT_PASSWORD=clinic-crm-password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=clinic-crm-local
S3_ACCESS_KEY=clinic-crm
S3_SECRET_KEY=clinic-crm-password
S3_FORCE_PATH_STYLE=true

# Sessions
SESSION_COOKIE_NAME=clinic_crm_session
SESSION_SECRET=change-me
SESSION_TTL_HOURS=12
SESSION_IDLE_TIMEOUT_MINUTES=15
SEED_ON_START=true

# Local bootstrap director
# In production, set these explicitly and do not use the default password.
BOOTSTRAP_DIRECTOR_PHONE=+70000000001
BOOTSTRAP_DIRECTOR_EMAIL=director@example.local
BOOTSTRAP_DIRECTOR_PASSWORD=ChangeMe123!
BOOTSTRAP_DIRECTOR_RESET_PASSWORD=false
