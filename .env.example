# App
NODE_ENV=development
PORT=3000
APP_URL=http://127.0.0.1:3000

# Database
POSTGRES_DB=clinic_crm
POSTGRES_USER=clinic_crm
POSTGRES_PASSWORD=clinic_crm
POSTGRES_PORT=5432
DATABASE_URL=postgresql://clinic_crm:clinic_crm@localhost:5432/clinic_crm

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# S3-compatible storage
MINIO_ROOT_USER=clinic-crm
MINIO_ROOT_PASSWORD=clinic-crm-password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=clinic-crm-local
S3_ACCESS_KEY=clinic-crm
S3_SECRET_KEY=clinic-crm-password
S3_FORCE_PATH_STYLE=true

# Sessions
SESSION_COOKIE_NAME=clinic_crm_session
SESSION_SECRET=change-me
