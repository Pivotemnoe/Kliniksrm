generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EmployeeStatus {
  ACTIVE
  BLOCKED
}

enum AnimalSex {
  MALE
  FEMALE
  UNKNOWN
}

enum QueueUrgency {
  PLANNED
  URGENT
}

enum QueueStatus {
  WAITING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AppointmentStatus {
  PLANNED
  ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum VisitStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum VisitType {
  PRIMARY
  FOLLOW_UP
}

enum TaskStatus {
  OPEN
  DONE
  CANCELLED
  ARCHIVED
}

enum NotificationChannel {
  INTERNAL
  TELEGRAM
  MAX
  SMS
  EMAIL
  PUSH
}

enum NotificationStatus {
  QUEUED
  SENDING
  SENT
  FAILED
  CANCELLED
}

enum ClientPortalStatus {
  DISABLED
  ENABLED
  INVITED
  BLOCKED
}

enum LaboratoryOrderStatus {
  ORDERED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum LaboratoryOrderItemStatus {
  ORDERED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
  CANCELLED
}

enum PaymentType {
  CASH
  CARD
  BANK_TRANSFER
  DEPOSIT
  OTHER
}

enum BillSource {
  VISIT
  SALE
  MANUAL
}

enum OnlineRequestStatus {
  NEW
  IN_REVIEW
  ACCEPTED
  CANCELLED
  ARCHIVED
}

enum StockMovementType {
  SUPPLY
  SALE
  VISIT_USAGE
  WRITE_OFF
  TRANSFER
  CORRECTION
}

enum DocumentStatus {
  DRAFT
  GENERATED
  SIGNED
  CANCELLED
}

enum FileVisibility {
  PRIVATE
  INTERNAL
  PUBLIC_LINK
}

enum JobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
  CANCELLED
}

enum NewsPriority {
  INFO
  IMPORTANT
  CRITICAL
}

enum PermissionEffect {
  GRANT
  DENY
}

enum MedicalPhraseSource {
  SYSTEM
  EMPLOYEE
  DIAGNOSIS_TEMPLATE
}

model User {
  id              String    @id @default(uuid())
  email           String?   @unique
  phone           String?   @unique @db.VarChar(32)
  phoneNormalized String?   @db.VarChar(16)
  passwordHash    String
  employee        Employee?
  sessions        Session[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([phoneNormalized])
}

model Employee {
  id                   String                       @id @default(uuid())
  userId               String?                      @unique
  user                 User?                        @relation(fields: [userId], references: [id], onDelete: SetNull)
  fullName             String
  phone                String?                      @db.VarChar(32)
  position             String?
  defaultRoute         String?
  restrictLoginToShifts Boolean                      @default(false)
  status               EmployeeStatus               @default(ACTIVE)
  roles                EmployeeRole[]
  permissionOverrides  EmployeePermissionOverride[]
  warehouseAccesses    EmployeeWarehouseAccess[]
  shifts               EmployeeShift[]
  queueEntries         QueueEntry[]
  appointments         Appointment[]
  visits               Visit[]
  assignedTasks        Task[]                       @relation("TaskAssignee")
  createdTasks         Task[]                       @relation("TaskCreator")
  createdNotifications NotificationOutbox[]         @relation("NotificationCreator")
  createdNewsPosts     NewsPost[]                   @relation("NewsPostCreator")
  newsReads            NewsPostRead[]
  auditLogs            AuditLog[]                   @relation("AuditActor")
  payments             Payment[]
  medicalPhrases       MedicalPhrase[]
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt

  @@index([fullName])
  @@index([phone])
}

model EmployeeShift {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  startsAt   DateTime
  endsAt     DateTime
  comment    String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([employeeId, startsAt])
  @@index([startsAt, endsAt])
}

model Role {
  id          String           @id @default(uuid())
  code        String           @unique
  title       String
  description String?
  employees   EmployeeRole[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id                String                       @id @default(uuid())
  code              String                       @unique
  title             String
  description       String?
  roles             RolePermission[]
  employeeOverrides EmployeePermissionOverride[]
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt
}

model EmployeeRole {
  employeeId String
  roleId     String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([employeeId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model EmployeePermissionOverride {
  employeeId   String
  permissionId String
  effect       PermissionEffect
  employee     Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  permission   Permission       @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@id([employeeId, permissionId])
  @@index([permissionId])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id         String    @id @default(uuid())
  actorId    String?
  actor      Employee? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime  @default(now())

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model Organization {
  id                 String         @id @default(uuid())
  displayName        String
  legalName          String?
  orgType            String?
  inn                String?
  kpp                String?
  legalAddress       String?
  postalAddress      String?
  bankName           String?
  bik                String?
  account            String?
  corrAccount        String?
  defaultBillDueDays Int?
  offices            ClinicOffice[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model ClinicOffice {
  id             String        @id @default(uuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  phone          String?       @db.VarChar(32)
  timezone       String        @default("Europe/Moscow")
  address        String?
  workingHours   Json?
  rooms          Room[]
  warehouses     Warehouse[]
  hospitalBoxes  HospitalBox[]
  cashboxes      Cashbox[]
  owners         Owner[]
  appointments   Appointment[]
  queueEntries   QueueEntry[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Room {
  id           String        @id @default(uuid())
  officeId     String
  office       ClinicOffice  @relation(fields: [officeId], references: [id], onDelete: Cascade)
  name         String
  queueEntries QueueEntry[]
  appointments Appointment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([officeId, name])
}

model Warehouse {
  id                String                    @id @default(uuid())
  officeId          String
  office            ClinicOffice              @relation(fields: [officeId], references: [id], onDelete: Cascade)
  name              String
  employeeAccesses  EmployeeWarehouseAccess[]
  batches           StockBatch[]
  supplyItems       SupplyInvoiceItem[]
  stockMovements    StockMovement[]           @relation("MovementWarehouse")
  incomingMovements StockMovement[]           @relation("MovementToWarehouse")
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@unique([officeId, name])
}

model EmployeeWarehouseAccess {
  employeeId  String
  warehouseId String
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@id([employeeId, warehouseId])
  @@index([warehouseId])
}

model HospitalBox {
  id        String       @id @default(uuid())
  officeId  String
  office    ClinicOffice @relation(fields: [officeId], references: [id], onDelete: Cascade)
  name      String
  visits    Visit[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([officeId, name])
}

model PaymentMethod {
  id        String      @id @default(uuid())
  title     String
  type      PaymentType
  isActive  Boolean     @default(true)
  sortOrder Int         @default(0)
  payments  Payment[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([title])
  @@index([isActive, sortOrder])
}

model Cashbox {
  id           String        @id @default(uuid())
  officeId     String?
  office       ClinicOffice? @relation(fields: [officeId], references: [id], onDelete: SetNull)
  title        String
  fiscalNumber String?
  isActive     Boolean       @default(true)
  payments     Payment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([officeId, title])
  @@index([isActive])
}

model Owner {
  id                           String                     @id @default(uuid())
  officeId                     String?
  office                       ClinicOffice?              @relation(fields: [officeId], references: [id], onDelete: SetNull)
  fullName                     String
  fullNameNormalized           String?                    @db.VarChar(240)
  organizationName             String?
  phone                        String?                    @db.VarChar(32)
  phoneNormalized              String?                    @db.VarChar(16)
  extraPhone                   String?                    @db.VarChar(32)
  email                        String?
  address                      String?
  source                       String?
  passportData                 String?
  comment                      String?
  preferredNotificationChannel NotificationChannel?
  telegramChatId               String?
  maxUserId                    String?
  allowSms                     Boolean                    @default(false)
  allowTelegram                Boolean                    @default(false)
  allowMax                     Boolean                    @default(false)
  allowEmail                   Boolean                    @default(false)
  portalAccess                 ClientPortalAccess?
  goodsDiscount                Decimal                    @default(0) @db.Decimal(5, 2)
  servicesDiscount             Decimal                    @default(0) @db.Decimal(5, 2)
  balance                      Decimal                    @default(0) @db.Decimal(12, 2)
  animals                      Animal[]
  trustedPeople                TrustedPerson[]
  queueEntries                 QueueEntry[]
  appointments                 Appointment[]
  visits                       Visit[]
  tasks                        Task[]
  bills                        Bill[]
  sales                        Sale[]
  balanceOperations            OwnerBalanceOperation[]
  notifications                NotificationOutbox[]
  onlineRequests               OnlineAppointmentRequest[]
  createdAt                    DateTime                   @default(now())
  updatedAt                    DateTime                   @updatedAt

  @@index([fullName])
  @@index([phone])
  @@index([phoneNormalized])
  @@index([fullNameNormalized, phoneNormalized])
  @@index([email])
}

model ClientPortalAccess {
  id                 String             @id @default(uuid())
  ownerId            String             @unique
  owner              Owner              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  status             ClientPortalStatus @default(DISABLED)
  inviteTokenHash    String?
  inviteExpiresAt    DateTime?
  invitedAt          DateTime?
  lastLoginAt        DateTime?
  loginCodeHash      String?
  loginCodeExpiresAt DateTime?
  loginCodeAttempts  Int                @default(0)
  blockedReason      String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([status])
  @@index([loginCodeExpiresAt])
}

model TrustedPerson {
  id        String   @id @default(uuid())
  ownerId   String
  owner     Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  fullName  String
  phone     String?  @db.VarChar(32)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

model Animal {
  id             String                     @id @default(uuid())
  ownerId        String
  owner          Owner                      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  nickname       String
  species        String?
  breed          String?
  sex            AnimalSex                  @default(UNKNOWN)
  birthDate      DateTime?
  color          String?
  microchip      String?
  mark           String?
  comment        String?
  isSterilized   Boolean                    @default(false)
  isFavorite     Boolean                    @default(false)
  status         String?
  weights        AnimalWeightRecord[]
  vaccinations   Vaccination[]
  queueEntries   QueueEntry[]
  appointments   Appointment[]
  visits         Visit[]
  tasks          Task[]
  bills          Bill[]
  sales          Sale[]
  notifications  NotificationOutbox[]
  onlineRequests OnlineAppointmentRequest[]
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  @@index([ownerId])
  @@index([nickname])
  @@index([microchip])
}

model AnimalSpecies {
  id        String        @id @default(uuid())
  code      String        @unique
  title     String        @unique
  sortOrder Int           @default(0)
  breeds    AnimalBreed[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([sortOrder])
}

model AnimalBreed {
  id        String        @id @default(uuid())
  speciesId String
  species   AnimalSpecies @relation(fields: [speciesId], references: [id], onDelete: Cascade)
  title     String
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([speciesId, title])
  @@index([speciesId, sortOrder])
  @@index([title])
}

model AnimalWeightRecord {
  id         String   @id @default(uuid())
  animalId   String
  animal     Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  weightKg   Decimal  @db.Decimal(7, 3)
  measuredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([animalId, measuredAt])
}

model Vaccination {
  id                String    @id @default(uuid())
  animalId          String
  animal            Animal    @relation(fields: [animalId], references: [id], onDelete: Cascade)
  title             String
  status            String?
  vaccinatedAt      DateTime?
  expiresAt         DateTime?
  vaccineBatch      String?
  vaccineSeries     String?
  vaccineExpiresAt  DateTime?
  smsReminder       Boolean   @default(false)
  notes             String?
  revaccinationTask Task?     @relation("VaccinationRevaccinationTask")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([animalId])
  @@index([vaccinatedAt])
  @@index([expiresAt])
}

model QueueEntry {
  id             String        @id @default(uuid())
  officeId       String?
  office         ClinicOffice? @relation(fields: [officeId], references: [id], onDelete: SetNull)
  ownerId        String?
  owner          Owner?        @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  animalId       String?
  animal         Animal?       @relation(fields: [animalId], references: [id], onDelete: SetNull)
  employeeId     String?
  employee       Employee?     @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  roomId         String?
  room           Room?         @relation(fields: [roomId], references: [id], onDelete: SetNull)
  ownerName      String?
  phone          String?       @db.VarChar(32)
  ownerAddress   String?
  animalNickname String?
  animalSpecies  String?
  animalBreed    String?
  animalSex      AnimalSex?
  visitType      VisitType?
  urgency        QueueUrgency  @default(PLANNED)
  status         QueueStatus   @default(WAITING)
  comment        String?
  visit          Visit?
  createdAt      DateTime      @default(now())
  startedAt      DateTime?
  lastCalledAt   DateTime?
  callCount      Int           @default(0)
  completedAt    DateTime?
  updatedAt      DateTime      @updatedAt

  @@index([status, createdAt])
  @@index([status, lastCalledAt])
  @@index([ownerId])
  @@index([animalId])
}

model Appointment {
  id            String                    @id @default(uuid())
  officeId      String?
  office        ClinicOffice?             @relation(fields: [officeId], references: [id], onDelete: SetNull)
  ownerId       String
  owner         Owner                     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  animalId      String
  animal        Animal                    @relation(fields: [animalId], references: [id], onDelete: Cascade)
  employeeId    String?
  employee      Employee?                 @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  roomId        String?
  room          Room?                     @relation(fields: [roomId], references: [id], onDelete: SetNull)
  startsAt      DateTime
  endsAt        DateTime?
  status        AppointmentStatus         @default(PLANNED)
  comment       String?
  visit         Visit?
  onlineRequest OnlineAppointmentRequest?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  @@index([startsAt])
  @@index([employeeId, startsAt])
  @@index([ownerId])
  @@index([animalId])
}

model OnlineAppointmentRequest {
  id              String              @id @default(uuid())
  status          OnlineRequestStatus @default(NEW)
  source          String              @default("PUBLIC_FORM")
  ownerName       String
  phone           String              @db.VarChar(32)
  email           String?
  animalNickname  String
  animalSpecies   String?
  animalBreed     String?
  preferredAt     DateTime?
  comment         String?
  internalComment String?
  ownerId         String?
  owner           Owner?              @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  animalId        String?
  animal          Animal?             @relation(fields: [animalId], references: [id], onDelete: SetNull)
  appointmentId   String?             @unique
  appointment     Appointment?        @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([status, createdAt])
  @@index([phone])
  @@index([ownerId])
  @@index([animalId])
}

model Visit {
  id               String               @id @default(uuid())
  ownerId          String
  owner            Owner                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  animalId         String
  animal           Animal               @relation(fields: [animalId], references: [id], onDelete: Cascade)
  employeeId       String?
  employee         Employee?            @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  appointmentId    String?              @unique
  appointment      Appointment?         @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  queueEntryId     String?              @unique
  queueEntry       QueueEntry?          @relation(fields: [queueEntryId], references: [id], onDelete: SetNull)
  hospitalBoxId    String?
  hospitalBox      HospitalBox?         @relation(fields: [hospitalBoxId], references: [id], onDelete: SetNull)
  visitType        VisitType?
  status           VisitStatus          @default(DRAFT)
  startedAt        DateTime             @default(now())
  completedAt      DateTime?
  totalAmount      Decimal              @default(0) @db.Decimal(12, 2)
  exam             VisitExam?
  diagnoses        VisitDiagnosis[]
  recommendation   VisitRecommendation?
  documents        VisitDocument[]
  files            FileObject[]
  bill             Bill?
  laboratoryOrders LaboratoryOrder[]
  stockMovements   StockMovement[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([ownerId])
  @@index([animalId])
  @@index([employeeId])
  @@index([startedAt])
}

model VisitExam {
  id            String   @id @default(uuid())
  visitId       String   @unique
  visit         Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
  purpose       String?
  anamnesis     String?
  examination   String?
  symptoms      String?
  manipulations String?
  weightKg      Decimal? @db.Decimal(7, 3)
  temperatureC  Decimal? @db.Decimal(4, 1)
  comment       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model VisitDiagnosis {
  id            String   @id @default(uuid())
  visitId       String
  visit         Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
  diagnosisType String?
  title         String
  description   String?
  status        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([visitId])
}

model VisitRecommendation {
  id            String   @id @default(uuid())
  visitId       String   @unique
  visit         Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
  treatmentPlan String?
  careNotes     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model MedicalPhrase {
  id         String              @id @default(uuid())
  field      String
  category   String?
  title      String
  text       String
  textHash   String
  species    String?
  diagnosis  String?
  source     MedicalPhraseSource @default(SYSTEM)
  scopeKey   String              @default("system")
  employeeId String?
  employee   Employee?           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  isActive   Boolean             @default(true)
  usageCount Int                 @default(0)
  lastUsedAt DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@unique([field, scopeKey, textHash])
  @@index([field, isActive])
  @@index([field, usageCount])
  @@index([employeeId, field])
  @@index([diagnosis])
  @@index([species])
}

model VisitDocument {
  id                String             @id @default(uuid())
  visitId           String
  visit             Visit              @relation(fields: [visitId], references: [id], onDelete: Cascade)
  templateId        String?
  template          DocumentTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  title             String
  body              String?
  status            DocumentStatus     @default(DRAFT)
  generatedDocument GeneratedDocument?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([visitId])
}

model NewsPost {
  id                String         @id @default(uuid())
  title             String
  body              String
  priority          NewsPriority   @default(INFO)
  isPinned          Boolean        @default(false)
  audienceRoleCodes String[]       @default([])
  createdById       String?
  createdBy         Employee?      @relation("NewsPostCreator", fields: [createdById], references: [id], onDelete: SetNull)
  reads             NewsPostRead[]
  publishedAt       DateTime       @default(now())
  archivedAt        DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([priority])
  @@index([isPinned, publishedAt])
  @@index([archivedAt])
}

model NewsPostRead {
  newsPostId String
  employeeId String
  newsPost   NewsPost @relation(fields: [newsPostId], references: [id], onDelete: Cascade)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  readAt     DateTime @default(now())

  @@id([newsPostId, employeeId])
  @@index([employeeId, readAt])
}

model Task {
  id                  String       @id @default(uuid())
  ownerId             String?
  owner               Owner?       @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  animalId            String?
  animal              Animal?      @relation(fields: [animalId], references: [id], onDelete: SetNull)
  assigneeId          String?
  assignee            Employee?    @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  assigneeRoleCode    String?
  creatorId           String?
  creator             Employee?    @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  sourceVaccinationId String?      @unique
  sourceVaccination   Vaccination? @relation("VaccinationRevaccinationTask", fields: [sourceVaccinationId], references: [id], onDelete: SetNull)
  taskType            String?
  title               String
  comment             String?
  status              TaskStatus   @default(OPEN)
  dueAt               DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([status, dueAt])
  @@index([ownerId])
  @@index([animalId])
  @@index([assigneeId])
  @@index([assigneeRoleCode])
}

model NotificationOutbox {
  id          String                @id @default(uuid())
  ownerId     String?
  owner       Owner?                @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  animalId    String?
  animal      Animal?               @relation(fields: [animalId], references: [id], onDelete: SetNull)
  templateId  String?
  template    NotificationTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdById String?
  createdBy   Employee?             @relation("NotificationCreator", fields: [createdById], references: [id], onDelete: SetNull)
  channel     NotificationChannel
  recipient   String
  subject     String?
  body        String
  status      NotificationStatus    @default(QUEUED)
  attempts    Int                   @default(0)
  scheduledAt DateTime              @default(now())
  sentAt      DateTime?
  lastError   String?
  metadata    Json?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([status, scheduledAt])
  @@index([channel])
  @@index([ownerId])
  @@index([animalId])
}

model ProductCategory {
  id        String    @id @default(uuid())
  title     String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id              String              @id @default(uuid())
  categoryId      String?
  category        ProductCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  title           String
  sku             String?
  gtin            String?
  barcode         String?
  vatRate         Decimal?            @db.Decimal(5, 2)
  retailPrice     Decimal             @default(0) @db.Decimal(12, 2)
  stockUnit       String?
  writeOffUnit    String?
  packageQuantity Decimal?            @db.Decimal(12, 3)
  minStock        Decimal?            @db.Decimal(12, 3)
  shelfLifeDays   Int?
  description     String?
  batches         StockBatch[]
  stockMovements  StockMovement[]
  supplyItems     SupplyInvoiceItem[]
  billItems       BillItem[]
  saleItems       SaleItem[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([title])
  @@index([barcode])
}

model ServiceCategory {
  id        String    @id @default(uuid())
  title     String    @unique
  services  Service[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Service {
  id                 String              @id @default(uuid())
  categoryId         String?
  category           ServiceCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  title              String
  price              Decimal             @default(0) @db.Decimal(12, 2)
  priceType          String              @default("FIXED")
  vatRate            Decimal?            @db.Decimal(5, 2)
  description        String?
  billItems          BillItem[]
  saleItems          SaleItem[]
  laboratoryTests    LaboratoryTest[]
  laboratoryProfiles LaboratoryProfile[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([title])
}

model LaboratoryTest {
  id             String                  @id @default(uuid())
  serviceId      String?
  service        Service?                @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  code           String?
  title          String
  groupName      String?
  material       String?
  method         String?
  unit           String?
  referenceRange String?
  species        String[]                @default([])
  description    String?
  isActive       Boolean                 @default(true)
  profileLinks   LaboratoryProfileTest[]
  orderItems     LaboratoryOrderItem[]
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([title])
  @@index([code])
  @@index([groupName])
  @@index([serviceId])
  @@index([isActive])
}

model LaboratoryProfile {
  id          String                  @id @default(uuid())
  serviceId   String?
  service     Service?                @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  code        String?
  title       String
  description String?
  species     String[]                @default([])
  isActive    Boolean                 @default(true)
  tests       LaboratoryProfileTest[]
  orderItems  LaboratoryOrderItem[]
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@index([title])
  @@index([code])
  @@index([serviceId])
  @@index([isActive])
}

model LaboratoryProfileTest {
  profileId String
  testId    String
  sortOrder Int               @default(0)
  profile   LaboratoryProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  test      LaboratoryTest    @relation(fields: [testId], references: [id], onDelete: Cascade)
  createdAt DateTime          @default(now())

  @@id([profileId, testId])
  @@index([testId])
  @@index([profileId, sortOrder])
}

model LaboratoryOrder {
  id          String                @id @default(uuid())
  visitId     String
  visit       Visit                 @relation(fields: [visitId], references: [id], onDelete: Cascade)
  status      LaboratoryOrderStatus @default(ORDERED)
  comment     String?
  createdById String?
  completedAt DateTime?
  items       LaboratoryOrderItem[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([visitId])
  @@index([status, createdAt])
  @@index([createdById])
}

model LaboratoryOrderItem {
  id             String                    @id @default(uuid())
  orderId        String
  order          LaboratoryOrder           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  testId         String?
  test           LaboratoryTest?           @relation(fields: [testId], references: [id], onDelete: SetNull)
  profileId      String?
  profile        LaboratoryProfile?        @relation(fields: [profileId], references: [id], onDelete: SetNull)
  billItemId     String?
  billItem       BillItem?                 @relation(fields: [billItemId], references: [id], onDelete: SetNull)
  status         LaboratoryOrderItemStatus @default(ORDERED)
  title          String
  code           String?
  groupName      String?
  material       String?
  method         String?
  unit           String?
  referenceRange String?
  resultValue    String?
  resultText     String?
  comment        String?
  completedAt    DateTime?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  @@index([orderId])
  @@index([testId])
  @@index([profileId])
  @@index([billItemId])
  @@index([status])
}

model Supplier {
  id             String          @id @default(uuid())
  title          String
  phone          String?         @db.VarChar(32)
  email          String?
  inn            String?
  comment        String?
  supplyInvoices SupplyInvoice[]
  stockBatches   StockBatch[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([title])
}

model StockBatch {
  id            String          @id @default(uuid())
  productId     String
  product       Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId   String
  warehouse     Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  supplierId    String?
  supplier      Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  quantity      Decimal         @default(0) @db.Decimal(12, 3)
  rest          Decimal         @default(0) @db.Decimal(12, 3)
  purchasePrice Decimal         @default(0) @db.Decimal(12, 2)
  expiresAt     DateTime?
  series        String?
  rack          String?
  rackNumber    String?
  shelfNumber   String?
  movements     StockMovement[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([productId])
  @@index([warehouseId])
  @@index([expiresAt])
}

model StockMovement {
  id            String            @id @default(uuid())
  productId     String
  product       Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  billItemId    String?
  billItem      BillItem?         @relation(fields: [billItemId], references: [id], onDelete: SetNull)
  stockBatchId  String?
  stockBatch    StockBatch?       @relation(fields: [stockBatchId], references: [id], onDelete: SetNull)
  warehouseId   String?
  warehouse     Warehouse?        @relation("MovementWarehouse", fields: [warehouseId], references: [id], onDelete: SetNull)
  toWarehouseId String?
  toWarehouse   Warehouse?        @relation("MovementToWarehouse", fields: [toWarehouseId], references: [id], onDelete: SetNull)
  visitId       String?
  visit         Visit?            @relation(fields: [visitId], references: [id], onDelete: SetNull)
  saleId        String?
  sale          Sale?             @relation(fields: [saleId], references: [id], onDelete: SetNull)
  type          StockMovementType
  quantity      Decimal           @db.Decimal(12, 3)
  comment       String?
  createdAt     DateTime          @default(now())

  @@index([productId])
  @@index([billItemId])
  @@index([warehouseId])
  @@index([type])
  @@index([createdAt])
}

model SupplyInvoice {
  id          String              @id @default(uuid())
  supplierId  String?
  supplier    Supplier?           @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  number      String?
  suppliedAt  DateTime            @default(now())
  totalAmount Decimal             @default(0) @db.Decimal(12, 2)
  items       SupplyInvoiceItem[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([supplierId])
  @@index([suppliedAt])
}

model SupplyInvoiceItem {
  id              String        @id @default(uuid())
  supplyInvoiceId String
  supplyInvoice   SupplyInvoice @relation(fields: [supplyInvoiceId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId     String
  warehouse       Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  quantity        Decimal       @db.Decimal(12, 3)
  purchasePrice   Decimal       @db.Decimal(12, 2)
  discountAmount  Decimal       @default(0) @db.Decimal(12, 2)
  expiresAt       DateTime?
  series          String?
  createdAt       DateTime      @default(now())

  @@index([supplyInvoiceId])
  @@index([productId])
}

model Bill {
  id          String        @id @default(uuid())
  ownerId     String?
  owner       Owner?        @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  animalId    String?
  animal      Animal?       @relation(fields: [animalId], references: [id], onDelete: SetNull)
  visitId     String?       @unique
  visit       Visit?        @relation(fields: [visitId], references: [id], onDelete: SetNull)
  saleId      String?       @unique
  sale        Sale?         @relation(fields: [saleId], references: [id], onDelete: SetNull)
  source      BillSource    @default(MANUAL)
  status      PaymentStatus @default(UNPAID)
  totalAmount Decimal       @default(0) @db.Decimal(12, 2)
  paidAmount  Decimal       @default(0) @db.Decimal(12, 2)
  dueAt       DateTime?
  items       BillItem[]
  payments    Payment[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([ownerId])
  @@index([animalId])
  @@index([status])
  @@index([dueAt])
  @@index([createdAt])
}

model BillItem {
  id                   String                @id @default(uuid())
  billId               String
  bill                 Bill                  @relation(fields: [billId], references: [id], onDelete: Cascade)
  productId            String?
  product              Product?              @relation(fields: [productId], references: [id], onDelete: SetNull)
  serviceId            String?
  service              Service?              @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  title                String
  quantity             Decimal               @default(1) @db.Decimal(12, 3)
  unitPrice            Decimal               @default(0) @db.Decimal(12, 2)
  discount             Decimal               @default(0) @db.Decimal(12, 2)
  totalAmount          Decimal               @default(0) @db.Decimal(12, 2)
  laboratoryOrderItems LaboratoryOrderItem[]
  stockMovements       StockMovement[]
  createdAt            DateTime              @default(now())

  @@index([billId])
}

model Payment {
  id              String         @id @default(uuid())
  billId          String
  bill            Bill           @relation(fields: [billId], references: [id], onDelete: Cascade)
  employeeId      String?
  employee        Employee?      @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  paymentMethodId String?
  paymentMethod   PaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  cashboxId       String?
  cashbox         Cashbox?       @relation(fields: [cashboxId], references: [id], onDelete: SetNull)
  type            PaymentType
  amount          Decimal        @db.Decimal(12, 2)
  paidAt          DateTime       @default(now())
  comment         String?
  createdAt       DateTime       @default(now())

  @@index([billId])
  @@index([paymentMethodId])
  @@index([cashboxId])
  @@index([paidAt])
}

model OwnerBalanceOperation {
  id        String      @id @default(uuid())
  ownerId   String
  owner     Owner       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  type      PaymentType
  amount    Decimal     @db.Decimal(12, 2)
  comment   String?
  createdAt DateTime    @default(now())

  @@index([ownerId])
  @@index([createdAt])
}

model Sale {
  id             String          @id @default(uuid())
  ownerId        String?
  owner          Owner?          @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  animalId       String?
  animal         Animal?         @relation(fields: [animalId], references: [id], onDelete: SetNull)
  totalAmount    Decimal         @default(0) @db.Decimal(12, 2)
  items          SaleItem[]
  bill           Bill?
  stockMovements StockMovement[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([ownerId])
  @@index([animalId])
  @@index([createdAt])
}

model SaleItem {
  id          String   @id @default(uuid())
  saleId      String
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  serviceId   String?
  service     Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  title       String
  quantity    Decimal  @default(1) @db.Decimal(12, 3)
  unitPrice   Decimal  @default(0) @db.Decimal(12, 2)
  discount    Decimal  @default(0) @db.Decimal(12, 2)
  totalAmount Decimal  @default(0) @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  @@index([saleId])
}

model DocumentTemplateCategory {
  id        String             @id @default(uuid())
  title     String             @unique
  templates DocumentTemplate[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model DocumentTemplate {
  id                 String                    @id @default(uuid())
  categoryId         String?
  category           DocumentTemplateCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  title              String
  body               String?
  variables          Json?
  visitDocuments     VisitDocument[]
  generatedDocuments GeneratedDocument[]
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  @@index([title])
}

model GeneratedDocument {
  id              String            @id @default(uuid())
  templateId      String?
  template        DocumentTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  visitDocumentId String?           @unique
  visitDocument   VisitDocument?    @relation(fields: [visitDocumentId], references: [id], onDelete: SetNull)
  fileId          String?
  file            FileObject?       @relation(fields: [fileId], references: [id], onDelete: SetNull)
  title           String
  status          DocumentStatus    @default(GENERATED)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model NotificationTemplate {
  id        String               @id @default(uuid())
  channel   String
  eventCode String
  title     String
  subject   String?
  body      String
  variables Json?
  isActive  Boolean              @default(true)
  messages  NotificationOutbox[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@unique([channel, eventCode])
  @@index([isActive])
}

model TemplateVariable {
  id          String   @id @default(uuid())
  code        String   @unique
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FileObject {
  id                 String              @id @default(uuid())
  visitId            String?
  visit              Visit?              @relation(fields: [visitId], references: [id], onDelete: SetNull)
  storageKey         String              @unique
  originalName       String
  mimeType           String?
  sizeBytes          Int?
  visibility         FileVisibility      @default(PRIVATE)
  generatedDocuments GeneratedDocument[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([visitId])
}

model BackupJob {
  id         String    @id @default(uuid())
  status     JobStatus @default(PENDING)
  storageKey String?
  startedAt  DateTime?
  finishedAt DateTime?
  error      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model BackgroundJob {
  id        String    @id @default(uuid())
  queueName String
  jobName   String
  status    JobStatus @default(PENDING)
  payload   Json?
  result    Json?
  error     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([queueName, status])
}
