{
  "name": "clinic-crm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "node server.mjs",
    "prototype:check": "node --check public/app.js && node --check server.mjs",
    "api:build": "npm --workspace @clinic-crm/api run build",
    "api:dev": "npm --workspace @clinic-crm/api run dev",
    "web:dev": "npm --workspace @clinic-crm/web run dev",
    "web:build": "npm --workspace @clinic-crm/web run build",
    "web:typecheck": "npm --workspace @clinic-crm/web run typecheck",
    "db:generate": "npm --workspace @clinic-crm/api run db:generate",
    "db:migrate": "npm --workspace @clinic-crm/api run db:migrate",
    "db:seed": "npm --workspace @clinic-crm/api run db:seed",
    "api:e2e": "node scripts/e2e-api.mjs",
    "clinic:start": "scripts/start-clinic-server.sh",
    "clinic:start:build": "scripts/start-clinic-server.sh --build",
    "clinic:start:open": "scripts/start-clinic-server.sh --open",
    "clinic:start:update": "scripts/start-clinic-server.sh --update-images --open",
    "clinic:download-docker-windows": "scripts/download-docker-windows-installer.sh",
    "clinic:make-flash": "scripts/create-portable-flash.sh",
    "clinic:make-flash:images": "scripts/create-portable-flash.sh --include-images --platform linux/amd64",
    "backup:local": "scripts/backup-local.sh",
    "backup:postgres": "scripts/backup-postgres.sh",
    "restore:local": "scripts/restore-local.sh",
    "infra:up": "docker compose up -d postgres redis minio",
    "infra:down": "docker compose down",
    "check": "npm run prototype:check && npm run api:build"
  },
  "engines": {
    "node": ">=22"
  }
}
